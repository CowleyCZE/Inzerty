# ===== DATABASE =====
# SQLite (default)
# DB_CLIENT=sqlite
# DATABASE_URL=./inzerty.db

# PostgreSQL (volitelné)
DB_CLIENT=postgres
DATABASE_URL="postgresql://inzerty_user:inzerty_password@localhost:5432/inzerty"
ENABLE_PGVECTOR=true

# ===== OLLAMA (AI) =====
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="all-minilm:22m"
MODE=auto

# ===== SERVER =====
NODE_ENV=development
PORT=3001
