/**
 * Český Inzertní Scraper UI - Backend Server
 */

import express from 'express';
import cors from 'cors';
import { initDb } from './database.js';
import { wsService } from './websocket.js';
import router from './routes/index.js';
import { ollamaManager } from './utils/ollama-manager.js';
import { runtimeLogger } from './utils/logger.js';

const app = express();
const port = 3001;
const WS_PORT = 3002;

process.on('uncaughtException', (err) => {
    console.error('Critical Uncaught Exception:', err);
    runtimeLogger.error(`Kritická chyba: ${err.message}`);
});

process.on('unhandledRejection', (reason, promise) => {
    console.error('Unhandled Rejection:', reason);
    runtimeLogger.error(`Nevyřízený slib: ${reason}`);
});

initDb().catch(console.error);
app.use(cors());
app.use(express.json({ limit: '50mb' }));
app.use(express.urlencoded({ limit: '50mb', extended: true }));
app.use(router);

wsService.initialize(WS_PORT);

app.get('/ws/stats', (req, res) => {
    res.json({ success: true, stats: wsService.getStats(), port: WS_PORT });
});

app.post('/ws/test', (req, res) => {
    const { userId, type, title, message } = req.body;
    const payload = {
        type: type || 'match_created',
        title: title || 'Testová notifikace',
        message: message || 'Toto je testová notifikace',
        timestamp: new Date().toISOString(),
        priority: 'low' as const,
    };
    if (userId) {
        wsService.sendToUser(userId, payload);
    } else {
        wsService.broadcast(payload);
    }
    res.json({ success: true, message: 'Notifikace odeslána' });
});

const startServer = () => {
    const server = app.listen(port, () => {
        runtimeLogger.success(`Backend server běží na http://localhost:${port}`);
        runtimeLogger.success(`WebSocket server běží na ws://localhost:${WS_PORT}`);
    });

    server.on('error', (err: any) => {
        if (err.code === 'EADDRINUSE') {
            runtimeLogger.error(`Port ${port} je obsazen!`);
            process.exit(1);
        }
        runtimeLogger.error(`Chyba serveru: ${err.message}`);
    });

    const shutdown = () => {
        server.close(() => {
            ollamaManager.dispose();
            wsService.dispose();
            process.exit(0);
        });
    };

    process.on('SIGINT', shutdown);
    process.on('SIGTERM', shutdown);
};

startServer();
process.stdin.resume();
